   "source": [
    "使用 `PyPTO` 编程进行验证:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "4cbfd0f1-2ff6-412f-bf66-1f5b3a6644f4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "在轴0上的求和：torch.Size([3, 4])\n",
      "在轴1上的求和：torch.Size([2, 4])\n",
      "在轴2上的求和：torch.Size([2, 3])\n"
     ]
    }
   ],
   "source": [
    "@pypto.frontend.jit(runtime_options={\"run_mode\": mode})\n",
    "def practice07_kernel(\n",
    "    a: pypto.Tensor([], pypto.DT_FP32),\n",
    "    out0: pypto.Tensor([], pypto.DT_FP32),    # sum(axis=0) → 去掉轴0\n",
    "    out1: pypto.Tensor([], pypto.DT_FP32),    # sum(axis=1) → 去掉轴1\n",
    "    out2: pypto.Tensor([], pypto.DT_FP32),    # sum(axis=2) → 去掉轴2\n",
    "):\n",
    "    pypto.set_vec_tile_shapes(2, 3, 8)\n",
    " \n",
    "    out0.move(pypto.sum(a, dim=0))    # 在轴0上求和\n",
    "    out1.move(pypto.sum(a, dim=1))    # 在轴1上求和\n",
    "    out2.move(pypto.sum(a, dim=2))    # 在轴2上求和\n",
    " \n",
    "\n",
    "A = torch.arange(24, dtype=torch.float32, device=device).reshape(2, 3, 4)\n",
    "out0 = torch.zeros((3, 4), dtype=torch.float32, device=device)\n",
    "out1 = torch.zeros((2, 4), dtype=torch.float32, device=device)\n",
    "out2 = torch.zeros((2, 3), dtype=torch.float32, device=device)\n",
    " \n",
    "# 执行\n",
    "practice07_kernel(A, out0, out1, out2)\n",
    " \n",
    "# 验证结果\n",
    "print(f\"在轴0上的求和：{out0.shape}\")\n",
    "print(f\"在轴1上的求和：{out1.shape}\")\n",
    "print(f\"在轴2上的求和：{out2.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a0356d71-5365-4493-a4df-13fc9275dfa4",
   "metadata": {},
   "source": [
    "## 练习 8\n",
    "为 `linalg.norm` 函数提供3个或更多轴的张量，并观察其输出。对于任意形状的张量这个函数计算得到什么？\n",
    "\n",
    "**解答：**\n",
    "\n",
    "在哪个轴上求范数，哪个轴就消失（被缩减）。以下使用 `torch` 编程验证："
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "24d7ce77-79ad-4d4f-9e4c-54f8ebae2b6f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "torch.Size([3, 4])\n",
      "torch.Size([2, 4])\n",
      "torch.Size([2, 3])\n"
     ]
    }
   ],
   "source": [
    "x = torch.randn(2, 3, 4)\n",
    "\n",
    "# 计算不同维度上的范数\n",
    "norm_dim0 = torch.linalg.norm(x, dim=0)\n",
    "print(norm_dim0.shape)\n",
    "\n",
    "norm_dim1 = torch.linalg.norm(x, dim=1)\n",
    "print(norm_dim1.shape)\n",
    "\n",
    "norm_dim2 = torch.linalg.norm(x, dim=2)\n",
    "print(norm_dim2.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "59cfb20a-82cb-40a1-8e35-2e3f01331fd3",
   "metadata": {},
   "source": [
    "使用 `PyPTO` 编程进行验证:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "5b4c0e4f-f22e-4af5-b2b7-a83d8f9744a1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "在轴0上的L2范数：torch.Size([3, 4])\n",
      "在轴1上的L2范数：torch.Size([2, 4])\n",
      "在轴2上的L2范数：torch.Size([2, 3])\n"
     ]
    }
   ],
   "source": [
    "@pypto.frontend.jit(runtime_options={\"run_mode\": mode})\n",
    "def practice08_kernel(\n",
    "    x: pypto.Tensor([2, 3, 4], pypto.DT_FP32),\n",
    "    out0: pypto.Tensor([3, 4], pypto.DT_FP32),   # dim=0 → (2,3,4) → (3,4)\n",
    "    out1: pypto.Tensor([2, 4], pypto.DT_FP32),   # dim=1 → (2,3,4) → (2,4)\n",
    "    out2: pypto.Tensor([2, 3], pypto.DT_FP32),   # dim=2 → (2,3,4) → (2,3)\n",
    "):\n",
    "    pypto.set_vec_tile_shapes(2, 3, 8)\n",
    "    \n",
    "    # dim=0: 在轴0上求L2范数\n",
    "    x_sq = pypto.mul(x, x)\n",
    "    s0 = pypto.sum(x_sq, dim=0)\n",
    "    out0.move(pypto.sqrt(s0))\n",
    " \n",
    "    # dim=1: 在轴1上求L2范数\n",
    "    s1 = pypto.sum(x_sq, dim=1)\n",
    "    out1.move(pypto.sqrt(s1))\n",
    " \n",
    "    # dim=2: 在轴2上求L2范数\n",
    "    s2 = pypto.sum(x_sq, dim=2)\n",
    "    out2.move(pypto.sqrt(s2))\n",
    " \n",
    "\n",
    "x = torch.randn(2, 3, 4, dtype=torch.float32, device=device)\n",
    " \n",
    "\n",
    "norm0 = torch.zeros((3, 4), dtype=torch.float32, device=device)\n",
    "norm1 = torch.zeros((2, 4), dtype=torch.float32, device=device)\n",
    "norm2 = torch.zeros((2, 3), dtype=torch.float32, device=device)\n",
    " \n",
    "practice08_kernel(x, norm0, norm1, norm2)\n",
    " \n",
    "print(f\"在轴0上的L2范数：{norm0.shape}\")\n",
    "print(f\"在轴1上的L2范数：{norm1.shape}\")\n",
    "print(f\"在轴2上的L2范数：{norm2.shape}\")"
   ]
  },
