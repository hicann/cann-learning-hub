using namespace AscendC;

using AType = matmul::MatmulType<TPosition::GM, CubeFormat::ND, int8_t>;
using BType = matmul::MatmulType<TPosition::GM, CubeFormat::NZ, int8_t>;
using CType = matmul::MatmulType<TPosition::GM, CubeFormat::ND, int32_t>;

namespace {

constexpr int64_t DEFAULT_M = 1;
constexpr int64_t DEFAULT_K = 4096;
constexpr int64_t DEFAULT_N = 24576;
constexpr float BF16_ATOL = 0.01f;
constexpr float BF16_RTOL = 0.01f;
constexpr size_t RESERVED_WORKSPACE_SIZE = 16 * 1024 * 1024;

void CheckAcl(aclError ret, const char* message)
{
    if (ret != ACL_SUCCESS) {
        const char* recent = aclGetRecentErrMsg();
        std::string detail = recent == nullptr ? "" : std::string(", detail=") + recent;
        throw std::runtime_error(std::string(message) + " failed, ret=" + std::to_string(ret) + detail);
    }
}

int64_t CeilDivHost(int64_t value, int64_t factor)
{
    return (value + factor - 1) / factor;
}

uint16_t FloatToBf16Bits(float value)
{
    uint32_t bits = 0;
    std::memcpy(&bits, &value, sizeof(bits));
    const uint32_t lsb = (bits >> 16) & 1U;
    const uint32_t roundingBias = 0x7FFFU + lsb;
    return static_cast<uint16_t>((bits + roundingBias) >> 16);
}

float Bf16BitsToFloat(uint16_t bits)
{
    const uint32_t value = static_cast<uint32_t>(bits) << 16;
    float result = 0.0f;
    std::memcpy(&result, &value, sizeof(result));
    return result;
}

std::vector<int8_t> MakeInt8Data(int64_t size, int64_t mul, int64_t add)
{
    std::vector<int8_t> data(static_cast<size_t>(size));
    for (int64_t i = 0; i < size; ++i) {
        data[static_cast<size_t>(i)] = static_cast<int8_t>((i * mul + add) % 255 - 128);
    }
    return data;
}

std::vector<float> MakeScaleData(int64_t size, float base, int64_t period, float step)
{
    std::vector<float> data(static_cast<size_t>(size));
    for (int64_t i = 0; i < size; ++i) {
        data[static_cast<size_t>(i)] = base + static_cast<float>((i % period) - period / 2) * step;
    }
    return data;
}

std::vector<int8_t> PackInt8NdToNz(const std::vector<int8_t>& nd, int64_t rows, int64_t cols)
{
    const int64_t colBlocks = CeilDivHost(cols, 32);
    const int64_t rowBlocks = CeilDivHost(rows, 16);
    std::vector<int8_t> nz(static_cast<size_t>(colBlocks * rowBlocks * 16 * 32), 0);
    for (int64_t r = 0; r < rows; ++r) {
        for (int64_t c = 0; c < cols; ++c) {
            const int64_t nzIndex = (((c / 32) * rowBlocks + (r / 16)) * 16 + (r % 16)) * 32 + (c % 32);
            nz[static_cast<size_t>(nzIndex)] = nd[static_cast<size_t>(r * cols + c)];
        }
    }
    return nz;
}

std::vector<int32_t> ReferenceInt32(const std::vector<int8_t>& x1, const std::vector<int8_t>& x2Nd,
                                    int64_t m, int64_t k, int64_t n)
{
    std::vector<int32_t> result(static_cast<size_t>(m * n), 0);
    for (int64_t row = 0; row < m; ++row) {
        for (int64_t col = 0; col < n; ++col) {
            int32_t acc = 0;
            for (int64_t kk = 0; kk < k; ++kk) {
                acc += static_cast<int32_t>(x1[static_cast<size_t>(row * k + kk)]) *
                       static_cast<int32_t>(x2Nd[static_cast<size_t>(kk * n + col)]);
            }
            result[static_cast<size_t>(row * n + col)] = acc;
        }
    }
    return result;
}

std::vector<uint16_t> ReferenceBf16(const std::vector<int32_t>& int32Result, const std::vector<float>& scale,
                                    const std::vector<float>& pertoken, int64_t m, int64_t n)
{
    std::vector<uint16_t> result(static_cast<size_t>(m * n), 0);
    for (int64_t row = 0; row < m; ++row) {
        for (int64_t col = 0; col < n; ++col) {
            const float value = static_cast<float>(int32Result[static_cast<size_t>(row * n + col)]) *
                                scale[static_cast<size_t>(col)] * pertoken[static_cast<size_t>(row)];
            result[static_cast<size_t>(row * n + col)] = FloatToBf16Bits(value);
        }
    }
    return result;
}

template <typename T>
void CopyHostToDevice(const std::vector<T>& host, uint8_t** device)
{
    const size_t bytes = host.size() * sizeof(T);
    CheckAcl(aclrtMalloc(reinterpret_cast<void**>(device), bytes, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc");
    CheckAcl(aclrtMemcpy(*device, bytes, host.data(), bytes, ACL_MEMCPY_HOST_TO_DEVICE), "aclrtMemcpy H2D");
}

template <typename T>
void AllocZeroDevice(size_t elementCount, uint8_t** device)
{
    std::vector<T> zero(elementCount, T{});
    CopyHostToDevice(zero, device);
}

template <typename T>
std::vector<T> CopyDeviceToHost(void* device, size_t elementCount)
{
    std::vector<T> host(elementCount);
    CheckAcl(aclrtMemcpy(host.data(), elementCount * sizeof(T), device, elementCount * sizeof(T),
                         ACL_MEMCPY_DEVICE_TO_HOST),
             "aclrtMemcpy D2H");
    return host;
}

bool CompareInt32(const std::vector<int32_t>& actual, const std::vector<int32_t>& ref)
{
    size_t mismatch = 0;
    for (size_t i = 0; i < actual.size(); ++i) {
        if (actual[i] != ref[i]) {
            if (mismatch < 5) {
                std::cout << "INT32 mismatch[" << i << "]: actual=" << actual[i] << ", ref=" << ref[i] << "\n";
            }
            ++mismatch;
        }
    }
    std::cout << "INT32 allclose: " << (mismatch == 0 ? "PASS" : "FAIL") << "\n";
    return mismatch == 0;
}

bool CompareBf16(const std::vector<uint16_t>& actual, const std::vector<uint16_t>& ref)
{
    size_t mismatch = 0;
    float maxAbsErr = 0.0f;
    for (size_t i = 0; i < actual.size(); ++i) {
        const float act = Bf16BitsToFloat(actual[i]);
        const float exp = Bf16BitsToFloat(ref[i]);
        const float absErr = std::fabs(act - exp);
        const float tol = BF16_ATOL + BF16_RTOL * std::fabs(exp);
        maxAbsErr = std::max(maxAbsErr, absErr);
        if (absErr > tol) {
            if (mismatch < 5) {
                std::cout << "BF16 mismatch[" << i << "]: actual=" << act << ", ref=" << exp
                          << ", abs_err=" << absErr << "\n";
            }
            ++mismatch;
        }
    }
    std::cout << "BF16 allclose: " << (mismatch == 0 ? "PASS" : "FAIL")
              << ", mismatch=" << mismatch << ", max_abs_err=" << maxAbsErr << "\n";
    return mismatch == 0;
}

template <typename T>
void PrintPrefix(const std::string& name, const std::vector<T>& data, size_t count)
{
    std::cout << name << " first " << std::min(count, data.size()) << ":";
    for (size_t i = 0; i < std::min(count, data.size()); ++i) {
        std::cout << " " << static_cast<int64_t>(data[i]);
    }
    std::cout << "\n";
}

QmmCustomTilingData GenerateQmmTiling(int32_t m, int32_t k, int32_t n, bool hasPertoken)
{
    auto platform = platform_ascendc::PlatformAscendCManager::GetInstance();
    matmul_tiling::MatmulApiTiling mmTiling(*platform);
    mmTiling.SetOrgShape(m, n, k);
    mmTiling.SetShape(m, n, k);
    mmTiling.SetAType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_INT8);
    mmTiling.SetBType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::NZ, matmul_tiling::DataType::DT_INT8);
    mmTiling.SetCType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_INT32);
    mmTiling.SetBias(false);

    QmmCustomTilingData tiling{};
    if (mmTiling.GetTiling(tiling.cubeTilingData) == -1) {
        throw std::runtime_error("MatmulApiTiling::GetTiling failed");
    }
    tiling.isPertoken = hasPertoken ? 1 : 0;
    tiling.M = m;
    tiling.N = n;
    tiling.K = k;
    tiling.singleCoreM = tiling.cubeTilingData.singleCoreM;
    tiling.singleCoreN = tiling.cubeTilingData.singleCoreN;
    tiling.workspaceSize = hasPertoken ? static_cast<uint64_t>(m) * n * sizeof(int32_t) : 0;
    return tiling;
}

int64_t ParseArg(char** argv, int index, int64_t fallback)
{
    return argv[index] == nullptr ? fallback : std::stoll(argv[index]);
}

} // namespace

__aicore__ inline int32_t CeilDivKernel(int32_t value, int32_t factor)
{
    return (value + factor - 1) / factor;
}

class QmmCubeBasicKernel {
public:
    __aicore__ inline QmmCubeBasicKernel() {}

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR y, QmmCustomTilingData* tilingData)
    {
        M = tilingData->M;
        N = tilingData->N;
        K = tilingData->K;

        x1GM.SetGlobalBuffer(reinterpret_cast<__gm__ int8_t*>(x1), M * K);
        x2GM.SetGlobalBuffer(reinterpret_cast<__gm__ int8_t*>(x2), K * N);
        yGM.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(y), M * N);

        mm.SetOrgShape(M, N, K);
        mm.SetTensorA(x1GM, false);
        mm.SetTensorB(x2GM, false);
    }

    __aicore__ inline void Process()
    {
        mm.IterateAll(yGM);
        mm.End();
    }

    matmul::Matmul<AType, BType, CType> mm;

private:
    int32_t M;
    int32_t N;
    int32_t K;
    GlobalTensor<int8_t> x1GM;
    GlobalTensor<int8_t> x2GM;
    GlobalTensor<int32_t> yGM;
};

class QmmPertokenKernel {
public:
    __aicore__ inline QmmPertokenKernel() {}

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR scale, GM_ADDR pertokenScale,
                                GM_ADDR y, GM_ADDR workspace, QmmCustomTilingData* tilingData,
                                TPipe* tPipe)
    {
        pipe = tPipe;
        M = tilingData->M;
        N = tilingData->N;
        K = tilingData->K;
        singleCoreM = tilingData->singleCoreM;
        singleCoreN = tilingData->singleCoreN;

        x1GM.SetGlobalBuffer(reinterpret_cast<__gm__ int8_t*>(x1), M * K);
        x2GM.SetGlobalBuffer(reinterpret_cast<__gm__ int8_t*>(x2), K * N);
        workspaceGM.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(GetUserWorkspace(workspace)), M * N);
        yGM.SetGlobalBuffer(reinterpret_cast<__gm__ bfloat16_t*>(y), M * N);
        scaleGM.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(scale), N);
        pertokenGM.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(pertokenScale), M);

        if ASCEND_IS_AIC {
            mm.SetOrgShape(M, N, K);
            mm.SetTensorA(x1GM, false);
            mm.SetTensorB(x2GM, false);
        }

        if ASCEND_IS_AIV {
            pipe->InitBuffer(intBuf, TILE_N * sizeof(int32_t));
            pipe->InitBuffer(floatBuf, TILE_N * sizeof(float));
            pipe->InitBuffer(scaleBuf, TILE_N * sizeof(float));
            pipe->InitBuffer(outBuf, TILE_N * sizeof(bfloat16_t));
        }
    }

    __aicore__ inline void Process()
    {
        if ASCEND_IS_AIC {
            mm.IterateAll(workspaceGM);
            mm.End();
            CrossCoreSetFlag<0x2, PIPE_FIX>(0);
        }

        if ASCEND_IS_AIV {
            CrossCoreWaitFlag(0);
            int32_t pairedAicIdx = static_cast<int32_t>(GetBlockIdx()) / 2;
            int32_t aivSubIdx = static_cast<int32_t>(GetBlockIdx()) % 2;
            int32_t mBlockCount = CeilDivKernel(M, singleCoreM);
            int32_t mBlockIdx = pairedAicIdx % mBlockCount;
            int32_t nBlockIdx = pairedAicIdx / mBlockCount;
            int32_t coreRowStart = mBlockIdx * singleCoreM;
            int32_t coreRowEnd = (coreRowStart + singleCoreM < M) ? (coreRowStart + singleCoreM) : M;
            int32_t coreColStart = nBlockIdx * singleCoreN;
            int32_t coreColEnd = (coreColStart + singleCoreN < N) ? (coreColStart + singleCoreN) : N;
            int32_t rowPerAiv = CeilDivKernel(coreRowEnd - coreRowStart, 2);
            int32_t rowStart = coreRowStart + aivSubIdx * rowPerAiv;
            int32_t rowEnd = (rowStart + rowPerAiv < coreRowEnd) ? (rowStart + rowPerAiv) : coreRowEnd;

            for (int32_t row = rowStart; row < rowEnd; ++row) {
                float pertokenVal = pertokenGM.GetValue(row);
                for (int32_t col = coreColStart; col < coreColEnd; col += TILE_N) {
                    int32_t curTile = (col + TILE_N <= coreColEnd) ? TILE_N : (coreColEnd - col);

                    LocalTensor<int32_t> intLocal = intBuf.Get<int32_t>();
                    LocalTensor<float> floatLocal = floatBuf.Get<float>();
                    LocalTensor<float> scaleLocal = scaleBuf.Get<float>();
                    LocalTensor<bfloat16_t> outLocal = outBuf.Get<bfloat16_t>();

                    DataCopy(intLocal, workspaceGM[row * N + col], curTile);
                    DataCopy(scaleLocal, scaleGM[col], curTile);

                    SetFlag<HardEvent::MTE2_V>(EVENT_ID0);
                    WaitFlag<HardEvent::MTE2_V>(EVENT_ID0);
                    Cast(floatLocal, intLocal, RoundMode::CAST_NONE, curTile);
                    PipeBarrier<PIPE_V>();
                    Mul(floatLocal, floatLocal, scaleLocal, curTile);
                    PipeBarrier<PIPE_V>();
                    Muls(floatLocal, floatLocal, pertokenVal, curTile);
                    PipeBarrier<PIPE_V>();
                    Cast(outLocal, floatLocal, RoundMode::CAST_RINT, curTile);
                    SetFlag<HardEvent::V_MTE3>(EVENT_ID1);
                    WaitFlag<HardEvent::V_MTE3>(EVENT_ID1);
                    DataCopy(yGM[row * N + col], outLocal, curTile);
                    SetFlag<HardEvent::MTE3_V>(EVENT_ID2);
                    WaitFlag<HardEvent::MTE3_V>(EVENT_ID2);
                }
            }
        }
    }

    matmul::Matmul<AType, BType, CType> mm;

private:
    static constexpr int32_t TILE_N = 4096;

    TPipe* pipe;
    int32_t M;
    int32_t N;
    int32_t K;
    int32_t singleCoreM;
    int32_t singleCoreN;

    TBuf<TPosition::VECCALC> intBuf;
    TBuf<TPosition::VECCALC> floatBuf;
    TBuf<TPosition::VECCALC> scaleBuf;
    TBuf<TPosition::VECCALC> outBuf;

    GlobalTensor<int8_t> x1GM;
    GlobalTensor<int8_t> x2GM;
    GlobalTensor<int32_t> workspaceGM;
    GlobalTensor<bfloat16_t> yGM;
    GlobalTensor<float> scaleGM;
    GlobalTensor<float> pertokenGM;
};

__global__ __mix__(1, 2) __aicore__ void qmm_custom_standalone(GM_ADDR x1, GM_ADDR x2, GM_ADDR scale,
                                                               GM_ADDR pertokenScale, GM_ADDR y,
                                                               __kfc_workspace__ GM_ADDR workspace,
                                                               QmmCustomTilingData tilingData)
{
    TPipe pipe;
    if (tilingData.isPertoken == 0) {
        if ASCEND_IS_AIC {
            QmmCubeBasicKernel kernel;
            REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), kernel.mm, &tilingData.cubeTilingData);
            kernel.Init(x1, x2, y, &tilingData);
            kernel.Process();
        }
    } else {
        QmmPertokenKernel kernel;
        if ASCEND_IS_AIC {
            REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), kernel.mm, &tilingData.cubeTilingData);
        }
        kernel.Init(x1, x2, scale, pertokenScale, y, workspace, &tilingData, &pipe);
        kernel.Process();
    }
    pipe.Destroy();
}

int32_t main(int32_t argc, char* argv[])
{
    const int64_t m64 = (argc > 1) ? ParseArg(argv, 1, DEFAULT_M) : DEFAULT_M;
    const int64_t k64 = (argc > 2) ? ParseArg(argv, 2, DEFAULT_K) : DEFAULT_K;
    const int64_t n64 = (argc > 3) ? ParseArg(argv, 3, DEFAULT_N) : DEFAULT_N;
    const int32_t m = static_cast<int32_t>(m64);
    const int32_t k = static_cast<int32_t>(k64);
    const int32_t n = static_cast<int32_t>(n64);

    uint8_t* x1Device = nullptr;
    uint8_t* x2Device = nullptr;
    uint8_t* scaleDevice = nullptr;
    uint8_t* pertokenDevice = nullptr;
    uint8_t* workspaceDevice = nullptr;
    uint8_t* int32OutDevice = nullptr;
    uint8_t* bf16OutDevice = nullptr;
    aclrtStream stream = nullptr;
    int32_t retCode = 0;

    try {
        std::cout << "Standalone QmmCustom kernel test: M=" << m << ", K=" << k << ", N=" << n << "\n";
        const auto x1 = MakeInt8Data(static_cast<int64_t>(m) * k, 17, 13);
        const auto x2Nd = MakeInt8Data(static_cast<int64_t>(k) * n, 19, 7);
        const auto x2Nz = PackInt8NdToNz(x2Nd, k, n);
        const auto scale = MakeScaleData(n, 0.25f, 13, 0.03125f);
        const auto pertoken = MakeScaleData(m, 0.5f, 7, 0.0625f);
        const auto int32Ref = ReferenceInt32(x1, x2Nd, m, k, n);
        const auto bf16Ref = ReferenceBf16(int32Ref, scale, pertoken, m, n);

        CheckAcl(aclInit(nullptr), "aclInit");
        CheckAcl(aclrtSetDevice(0), "aclrtSetDevice");
        CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream");

        CopyHostToDevice(x1, &x1Device);
        CopyHostToDevice(x2Nz, &x2Device);
        CopyHostToDevice(scale, &scaleDevice);
        CopyHostToDevice(pertoken, &pertokenDevice);
        AllocZeroDevice<int32_t>(static_cast<size_t>(m) * n, &int32OutDevice);
        AllocZeroDevice<uint16_t>(static_cast<size_t>(m) * n, &bf16OutDevice);

        auto platform = platform_ascendc::PlatformAscendCManager::GetInstance();
        const size_t systemWorkspaceSize =
            std::max(static_cast<size_t>(platform->GetLibApiWorkSpaceSize()), RESERVED_WORKSPACE_SIZE);
        const size_t userWorkspaceSize = static_cast<size_t>(m) * n * sizeof(int32_t);
        CheckAcl(aclrtMalloc(reinterpret_cast<void**>(&workspaceDevice), userWorkspaceSize + systemWorkspaceSize,
                             ACL_MEM_MALLOC_HUGE_FIRST),
                 "aclrtMalloc workspace");

        QmmCustomTilingData int32Tiling = GenerateQmmTiling(m, k, n, false);
        uint32_t int32Blocks = int32Tiling.cubeTilingData.usedCoreNum;
        std::cout << "[INT32] usedCoreNum=" << int32Blocks << ", singleCoreM=" << int32Tiling.singleCoreM
                  << ", singleCoreN=" << int32Tiling.singleCoreN << "\n";
        qmm_custom_standalone<<<int32Blocks, nullptr, stream>>>(x1Device, x2Device, scaleDevice, pertokenDevice,
                                                                int32OutDevice, workspaceDevice, int32Tiling);
        CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream INT32");
        auto int32Actual = CopyDeviceToHost<int32_t>(int32OutDevice, static_cast<size_t>(m) * n);
        PrintPrefix("actual INT32 y", int32Actual, 16);
        PrintPrefix("reference INT32 y", int32Ref, 16);
        const bool int32Ok = CompareInt32(int32Actual, int32Ref);

        QmmCustomTilingData bf16Tiling = GenerateQmmTiling(m, k, n, true);
        uint32_t bf16Blocks = bf16Tiling.cubeTilingData.usedCoreNum;
        std::cout << "[BF16] usedCoreNum=" << bf16Blocks << ", singleCoreM=" << bf16Tiling.singleCoreM
                  << ", singleCoreN=" << bf16Tiling.singleCoreN << "\n";
        qmm_custom_standalone<<<bf16Blocks, nullptr, stream>>>(x1Device, x2Device, scaleDevice, pertokenDevice,
                                                               bf16OutDevice, workspaceDevice, bf16Tiling);
        CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream BF16");
        auto bf16Actual = CopyDeviceToHost<uint16_t>(bf16OutDevice, static_cast<size_t>(m) * n);
        const bool bf16Ok = CompareBf16(bf16Actual, bf16Ref);

        retCode = (int32Ok && bf16Ok) ? 0 : 1;
    } catch (const std::exception& ex) {
        std::cerr << ex.what() << "\n";
        retCode = 1;
    }

    if (x1Device != nullptr) {
        aclrtFree(x1Device);
    }
    if (x2Device != nullptr) {
        aclrtFree(x2Device);
    }
    if (scaleDevice != nullptr) {
        aclrtFree(scaleDevice);
    }
    if (pertokenDevice != nullptr) {
        aclrtFree(pertokenDevice);
    }
    if (workspaceDevice != nullptr) {
        aclrtFree(workspaceDevice);
    }
    if (int32OutDevice != nullptr) {
        aclrtFree(int32OutDevice);
    }
    if (bf16OutDevice != nullptr) {
        aclrtFree(bf16OutDevice);
    }
    if (stream != nullptr) {
        aclrtDestroyStream(stream);
    }
    aclrtResetDevice(0);
    aclFinalize();
    return retCode;
}
