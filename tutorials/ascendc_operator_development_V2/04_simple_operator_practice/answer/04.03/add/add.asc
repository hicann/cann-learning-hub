#include <iostream>
#include <vector>
#include <iterator>
#include <random>
#include "acl/acl.h"
#include "add.h"

// ======================= 构造随机数据 =========================
int64_t random_key()
{
    static std::random_device rd;
    static std::mt19937_64 gen(rd());
    static std::uniform_int_distribution<int64_t> dist(0, std::numeric_limits<int64_t>::max());
    return dist(gen);
}

float random_value()
{
    static std::random_device rd;
    static std::mt19937_64 gen(rd());
    static std::uniform_real_distribution<double> dist(0.0, 1.0); // 模板随机 value [0,1]
    return static_cast<float>(dist(gen));
}

void generate_test_data(std::vector<float>& values, uint32_t num)
{
    int64_t key = random_key();
    values.resize(num);

    for (uint32_t i = 0; i < num; ++i) {
        values[i] = random_value();
    }
}

// ======================= 构造golden数据 =========================
std::vector<float> add_reference(std::vector<float>& src0, std::vector<float>& src1, uint32_t width)
{
    // 支持 float 和 half 数据类型。half 类型先 cast 为 float 进行计算。
    std::vector<float> dst(src0.size());
    for (uint32_t i = 0; i < width; ++i) {
        dst[i] = src0[i] + src1[i];
    }
    return dst;
}

// ======================= 校验输出结果 =========================
uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_fun = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t maxPrintSize = 20;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), maxPrintSize),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > maxPrintSize) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };

    print_fun(output, "Output");
    print_fun(golden, "Golden");
    // half 类型精度低，使用更大的容差
    constexpr float epsilon = std::is_same_v<float, half> ? 5e-3f : 1e-4f;
    bool passed = true;
    uint32_t errCount = 0;
    for (size_t i = 0; i < golden.size(); i++) {
        if (std::abs(static_cast<float>(output[i]) - static_cast<float>(golden[i])) > epsilon) {
            passed = false;
            errCount++;
        }
    }
    if (passed) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy is verification failed! errCount:" << errCount << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t dim = 1;
    constexpr uint32_t width = SINGLE_VF_DATA_LEN * LOOP_COUNT;
    constexpr uint32_t totalLen = width;

    std::vector<float> src0(totalLen);
    std::vector<float> src1(totalLen);
    generate_test_data(src0, width);
    generate_test_data(src1, width);
    size_t input_size = totalLen * sizeof(float);
    uint8_t* src0_device = nullptr;
    uint8_t* src1_device = nullptr;
    uint8_t* dst_device = nullptr;
    
    aclInit(nullptr);
    aclrtSetDevice(0);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    
    aclrtMalloc((void**)&src0_device, input_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&src1_device, input_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dst_device, input_size, ACL_MEM_MALLOC_HUGE_FIRST);
    
    aclrtMemcpy(src0_device, input_size, src0.data(), input_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src1_device, input_size, src1.data(), input_size, ACL_MEMCPY_HOST_TO_DEVICE);
    
    add_custom<<<dim, 0, stream>>>(src0_device, src1_device, dst_device);
    aclrtSynchronizeStream(stream);

    std::vector<float> output(totalLen);
    aclrtMemcpy(output.data(), input_size, dst_device, input_size, ACL_MEMCPY_DEVICE_TO_HOST);

    std::vector<float> golden = add_reference(src0, src1, width);
    uint32_t result = verify_result(output, golden);
    
    aclrtFree(src0_device);
    aclrtFree(src1_device);
    aclrtFree(dst_device);

    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return result;
}
