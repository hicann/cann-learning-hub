/* !
 * \file mmad_leakyrelu_basic_api.asc
 * \brief ňč║ń║ÄÚŁÖŠÇüTensorš╝ľšĘőŠĘíň╝Ćň«×šÄ░MMADňĺîLeakyReluŔ×ŹňÉłŔ«íš«Ś´╝îň▒ĽšĄ║CubeňŹĽňůâňĺîVectorňŹĽňůâňŹĆňÉîŔ«íš«ŚšÜäš╝ľšĘőŠĘíň╝ĆŃÇé
 *        ŠáĚńżőščęÚśÁŔžäŠá╝ńŞ║M=512ŃÇüK=128ŃÇüN=128´╝îŠîësingleCoreM=256ŃÇüsingleCoreN=128ňłćŠáŞňÉÄ´╝îńŻ┐šöĘ2ńŞ¬CubeŠáŞňĺî4ńŞ¬VectorŠáŞň«îŠłÉŔ«íš«ŚŃÇé
 *        šíČń╗ÂCube:VectorŠáŞŠĽ░Š»öńżőńŞ║1:2´╝î2ńŞ¬CubeŠáŞŔ┤čŔ┤úMMADŔ«íš«Ś´╝îŠ»ĆńŞ¬CubeŠáŞń║žšöčšÜäš╗ôŠ×ťňćŹšö▒2ńŞ¬VectorŠáŞňŹĆňÉîň«îŠłÉLeakyReluŠ┐ÇŠ┤╗Ŕ«íš«ŚŃÇé
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "mmad_leakyrelu_operator.h"
#include "data_utils.h"
#include <cstdlib>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

int32_t main(int32_t argc, char* argv[])
{
    // mmadňĆéŠĽ░
    constexpr uint32_t M = 512;
    constexpr uint32_t K = 128;
    constexpr uint32_t N = 128;
    // ňŹĽŠáŞŔ«íš«ŚÚçĆ
    constexpr uint32_t singleCoreM = 256;
    constexpr uint32_t singleCoreK = 128;
    constexpr uint32_t singleCoreN = 128;
    // ščęÚśÁń╣śŠëžŔíîňŹĽňůâTileňĆéŠĽ░
    constexpr uint32_t baseM = 256;
    constexpr uint32_t baseK = 128;
    constexpr uint32_t baseN = 128;

    size_t aFileSize = M * K * sizeof(half);
    size_t bFileSize = K * N * sizeof(half);
    size_t biasFileSize = N * sizeof(half);
    size_t cFileSize = M * N * sizeof(half);
    uint32_t numBlocks = (M / singleCoreM) * (N / singleCoreN);

    aclInit(nullptr);
    const char* deviceIdEnv = std::getenv("SAMPLE_DEVICE_ID");
    int32_t deviceId = deviceIdEnv == nullptr ? 0 : std::atoi(deviceIdEnv);
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    if (!ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize)) {
        ERROR_LOG("Read input file failed.");
        aclFinalize();
        return 1;
    }
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    if (!ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize)) {
        ERROR_LOG("Read input file failed.");
        aclFinalize();
        return 1;
    }
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* biasHost;
    uint8_t* biasDevice;
    aclrtMallocHost((void**)(&biasHost), biasFileSize);
    aclrtMalloc((void**)&biasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    if (!ReadFile("./input/bias_gm.bin", biasFileSize, biasHost, biasFileSize)) {
        ERROR_LOG("Read input file failed.");
        aclFinalize();
        return 1;
    }
    aclrtMemcpy(biasDevice, biasFileSize, biasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_leakyrelu_custom<M, K, N, singleCoreM, singleCoreK, singleCoreN, baseM, baseK, baseN>
        <<<numBlocks, nullptr, stream>>>(aDevice, bDevice, biasDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(biasDevice);
    aclrtFreeHost(biasHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
